# Copy to .env and fill in real values.
# bin/upload and bin/tf auto-load this file.
# Terraform reads TF_VAR_* environment variables.

# Cloudflare account details (used by Terraform + upload endpoint)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# Terraform inputs
TF_VAR_cloudflare_account_id="${CLOUDFLARE_ACCOUNT_ID}"
TF_VAR_cloudflare_api_token="${CLOUDFLARE_API_TOKEN}"
TF_VAR_r2_bucket_name="railsperf-exports"
TF_VAR_r2_object_key="railsperf-export-latest.zip"

# Upload target
R2_ACCOUNT_ID="${CLOUDFLARE_ACCOUNT_ID}"
R2_BUCKET="${TF_VAR_r2_bucket_name}"
R2_OBJECT_KEY="${TF_VAR_r2_object_key}"
R2_BACKUP_PREFIX="backups"

# Upload credentials (R2 token with Object Read & Write)
R2_UPLOAD_ACCESS_KEY_ID=""
R2_UPLOAD_SECRET_ACCESS_KEY=""

# Optional: when using temporary credentials
# R2_UPLOAD_SESSION_TOKEN=""

# Optional: presigned upload URLs.
# If R2_PRESIGNED_PUT_URL is set, bin/upload uses curl for the latest object.
# Set R2_PRESIGNED_BACKUP_PUT_URL too if you also want immutable backups in presigned mode.
# R2_PRESIGNED_PUT_URL=""
# R2_PRESIGNED_BACKUP_PUT_URL=""

# Optional: skip AWS profile/config resolution for cleaner aws-cli behavior
AWS_REGION="auto"
